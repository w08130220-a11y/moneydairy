# Copy this file to .env for local development.
# On Vercel, set these in Project Settings → Environment Variables
# (DATABASE_URL & BLOB_READ_WRITE_TOKEN 會在綁定 Neon + Blob 時自動填入)

# PostgreSQL connection string (Neon / Vercel Postgres)
# Format: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=""

# NextAuth session signing — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Required for NextAuth v5 on serverless hosts
AUTH_TRUST_HOST=true

# Vercel Blob storage token (auto-set by Vercel when Blob is attached)
# Leave empty for local dev — uploads will fall back to ./uploads/
BLOB_READ_WRITE_TOKEN=""
