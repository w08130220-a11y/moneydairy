generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  createdAt    DateTime   @default(now())
  campaigns    Campaign[]
}

model Campaign {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  vendor        String
  platform      String
  productUrl    String?
  notes         String?

  startDate     DateTime
  dueDate       DateTime?
  postedDate    DateTime?
  paidDate      DateTime?

  revenue       Float
  revenueStatus String    @default("PENDING") // PENDING | RECEIVED

  status        String    @default("PLANNED") // PLANNED | IN_PROGRESS | DONE | CANCELLED

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expenses      Expense[]
  videoAuths    VideoAuth[]

  @@index([userId])
  @@index([startDate])
  @@index([dueDate])
}

model VideoAuth {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  videoTitle   String              // 影片名稱 / 說明
  videoUrl     String?             // 影片連結 (選填)
  grantedAt    DateTime            // 授權開始日
  expiresAt    DateTime            // 授權到期日
  notes        String?
  createdAt    DateTime @default(now())

  @@index([campaignId])
  @@index([expiresAt])
}

model Expense {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category    String
  description String
  amount      Float
  spentAt     DateTime
  invoiceFile String?
  createdAt   DateTime @default(now())

  @@index([campaignId])
}
